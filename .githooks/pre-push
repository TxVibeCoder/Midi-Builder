#!/bin/sh
# Blocks pushes that would publish secrets or oversized blobs, even if they
# slipped past pre-commit (e.g. commits made with --no-verify or on another
# machine without hooksPath configured). Installed via:
#   git config core.hooksPath .githooks
set -e

MAX_BYTES=5242880  # 5 MB
ZERO=0000000000000000000000000000000000000000
secret_pattern='(AKIA[0-9A-Z]{16}|-----BEGIN [A-Z ]*PRIVATE KEY-----|xox[baprs]-[0-9A-Za-z-]{10,}|sk-[A-Za-z0-9]{20,}|api[_-]?key["\x27]?\s*[:=]\s*["\x27][A-Za-z0-9_\-]{16,})'

fail=0
while read -r _local_ref local_sha _remote_ref remote_sha; do
    [ "$local_sha" = "$ZERO" ] && continue  # branch deletion
    if [ "$remote_sha" = "$ZERO" ]; then
        range="$local_sha --not --remotes"   # new branch: everything not already remote
    else
        range="$remote_sha..$local_sha"
    fi

    # filenames matching secrets patterns anywhere in the outgoing commits
    names=$(git log --pretty=format: --name-only $range | sort -u | \
        grep -Ei '(^|/)\.env(\.|$)|\.pem$|\.key$|credentials.*\.json|secret' || true)
    if [ -n "$names" ]; then
        echo "PUSH BLOCKED: outgoing commits touch secrets-pattern filenames:" >&2
        echo "$names" >&2
        fail=1
    fi

    # secret-like strings in outgoing diffs
    match=$(git log -p --pretty=format: $range | grep -Eno "$secret_pattern" | head -1) || true
    if [ -n "$match" ]; then
        echo "PUSH BLOCKED: outgoing diff contains a secret-like string ($match)." >&2
        fail=1
    fi

    # oversized blobs reachable from the outgoing commits
    big=$(git rev-list --objects $range | \
        git cat-file --batch-check='%(objecttype) %(objectsize) %(rest)' 2>/dev/null | \
        awk -v max=$MAX_BYTES '$1=="blob" && $2>max {print $2, $3}') || true
    if [ -n "$big" ]; then
        echo "PUSH BLOCKED: outgoing commits contain blobs over ${MAX_BYTES} bytes:" >&2
        echo "$big" >&2
        fail=1
    fi
done

if [ "$fail" -ne 0 ]; then
    echo "" >&2
    echo "Push rejected by .githooks/pre-push. Remove the offending content from history" >&2
    echo "(or confirm a false positive with the user) before pushing." >&2
    exit 1
fi
exit 0
